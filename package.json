{
  "name": "reqlens-api",
  "version": "0.1.0",
  "private": true,
  "description": "Reqlens ingest API and dashboard backend.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
