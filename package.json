{
  "name": "reqlens-api",
  "version": "0.1.0",
  "private": true,
  "description": "Reqlens ingest API and dashboard backend.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "email:dev": "email dev --dir src/emails --port 3002",
    "email:export": "email export --dir src/emails"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "better-auth": "^1.6.9",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-email/ui": "^6.0.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "prisma": "^7.8.0",
    "react-email": "^6.0.8",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
